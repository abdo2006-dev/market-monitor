# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://market:market@localhost:5432/market_monitor

# ─── Cache / Queue ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ─── Locale ──────────────────────────────────────────────────────────────────
DEFAULT_TIMEZONE=UTC
DEFAULT_CURRENCY=USD

# ─── Scraping ────────────────────────────────────────────────────────────────
# Browser user-agent sent with every request
USER_AGENT=MarketMonitor/1.0 (price monitoring bot; contact your@email.com)

# Run Playwright in headless mode (true recommended for servers)
PLAYWRIGHT_HEADLESS=true

# ─── Discord ─────────────────────────────────────────────────────────────────
# Master on/off switch for all Discord notifications
DISCORD_NOTIFICATIONS_ENABLED=true

# Per-competitor webhooks are set inside the competitor record.
# You can also set a global fallback webhook here if desired.
# DISCORD_DEFAULT_WEBHOOK_URL=https://discord.com/api/webhooks/...
