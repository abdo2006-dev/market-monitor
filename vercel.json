{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "api": {
      "entrypoint": "backend/main.py",
      "routePrefix": "/api",
      "memory": 2048,
      "maxDuration": 300,
      "includeFiles": "backend/app/**"
    },
    "web": {
      "entrypoint": "frontend",
      "routePrefix": "/"
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 8 * * *"
    }
  ]
}
